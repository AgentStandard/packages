{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentstandard.ai/schema/v1.json",
  "title": "AgentStandard Package Manifest",
  "description": "Schema for AgentStandard agent package manifests (v1)",
  "type": "object",
  "required": ["id", "name", "slug", "version", "description", "meta", "setup_steps"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "description": "Unique package identifier (slugified)" },
    "name": { "type": "string", "description": "Human-readable package name" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string", "maxLength": 300 },
    "tagline": { "type": "string", "maxLength": 80 },
    "meta": {
      "type": "object",
      "required": ["author", "published", "vertical", "tier", "platform"],
      "properties": {
        "author": { "type": "string" },
        "published": { "type": "string", "format": "date" },
        "updated": { "type": "string", "format": "date" },
        "vertical": { "type": "string", "enum": ["general", "finance", "ecommerce", "content", "dev", "seo", "other"] },
        "tier": { "type": "string", "enum": ["starter", "pro", "max"] },
        "platform": { "type": "array", "items": { "type": "string" } },
        "license": { "type": "string" }
      }
    },
    "certification": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["uncertified", "community", "agentstandard-certified"] },
        "certified_date": { "type": ["string", "null"] },
        "benchmark_score": { "type": ["number", "null"] },
        "certifier": { "type": ["string", "null"] }
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "setup_time_minutes": { "type": "integer" },
        "installs": { "type": "integer" },
        "upvotes": { "type": "integer" },
        "avg_rating": { "type": ["number", "null"] }
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "required"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "version": { "type": "string" },
          "required": { "type": "boolean" }
        }
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "source": { "type": "string", "enum": ["clawhub", "github", "mcp.so", "custom"] },
          "url": { "type": "string", "format": "uri" },
          "version": { "type": "string" },
          "hash": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "version": { "type": "string" },
          "hash": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "env_vars": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "description", "required"],
            "properties": {
              "key": { "type": "string" },
              "description": { "type": "string" },
              "required": { "type": "boolean" },
              "sensitive": { "type": "boolean" },
              "where_to_get": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "setup_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "title", "description", "type"],
        "properties": {
          "order": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "command": { "type": "string" },
          "estimated_minutes": { "type": "integer" },
          "type": { "type": "string", "enum": ["install", "config", "command", "browse", "done"] }
        }
      }
    },
    "benchmarks": {
      "type": "object",
      "properties": {
        "tested_on": { "type": "array", "items": { "type": "string" } },
        "task_completion_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "avg_response_ms": { "type": "integer" },
        "estimated_cost_per_session_usd": { "type": "number" },
        "tested_date": { "type": "string", "format": "date" }
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "caption": { "type": "string" }
        }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "keywords": {
      "type": "array",
      "description": "3-8 tags from the AgentStandard controlled taxonomy. Required for certification.",
      "items": { "type": "string" },
      "minItems": 0,
      "maxItems": 8
    },
    "user_level": {
      "type": "string",
      "description": "Primary user level this package targets.",
      "enum": ["beginner", "intermediate", "advanced", "developer"]
    },
    "system_prompt": {
      "type": "string",
      "description": "The complete system prompt used by this agent. Required for certification. Hidden instructions not declared here will result in automatic rejection. Use empty string if no system prompt."
    },
    "data_access": {
      "type": "array",
      "description": "List of sensitive data categories this agent accesses. Required for certification.",
      "items": {
        "type": "string",
        "enum": ["email", "calendar", "files", "financial", "contacts", "location", "health", "none"]
      }
    },
    "external_services": {
      "type": "array",
      "description": "Third-party APIs or services this agent calls. Required for certification.",
      "items": { "type": "string" }
    },
    "tos_links": {
      "type": "array",
      "description": "Terms of Service links for each external service listed in external_services.",
      "items": { "type": "string", "format": "uri" }
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "notes"],
        "properties": {
          "version": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
