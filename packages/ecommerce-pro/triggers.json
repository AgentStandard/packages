{
  "slug": "ecommerce-pro",
  "activation": {
    "explicit_command": "@ecommerce-pro",
    "phrases": [
      "ecommerce-pro mode",
      "help me with ecommerce os",
      "start ecommerce os",
      "I need ecommerce os",
      "help with ecommerce",
      "help with DTC",
      "help with shopify"
    ],
    "context_signals": [
      "user mentions ecommerce or DTC topics"
    ]
  },
  "deactivation": {
    "explicit_command": "@default",
    "phrases": [
      "done",
      "exit",
      "exit ecommerce-pro",
      "stop ecommerce os",
      "back to normal"
    ],
    "auto_deactivate": {
      "after_unrelated_turns": 3,
      "on_session_end": true,
      "after_minutes_idle": 30
    }
  },
  "scope": "session",
  "singleton": true,
  "persona_name": "Storefront"
}