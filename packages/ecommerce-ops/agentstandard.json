{
  "$schema": "https://agentstandard.ai/schema/v1.json",
  "id": "ecommerce-ops",
  "name": "Ecommerce Ops Stack",
  "slug": "ecommerce-ops",
  "version": "1.0.0",
  "description": "Shopify monitoring, inventory alerts, customer comms, and order ops — handled by your agent so you can focus on growth.",
  "tagline": "Shopify, inventory, and customer comms on autopilot.",

  "meta": {
    "author": "agentstandard",
    "published": "2026-03-03",
