{
  "slug": "negotiation-coach",
  "activation": {
    "explicit_command": "@negotiation-coach",
    "phrases": [
      "negotiation-coach mode",
      "help me with negotiation coach",
      "start negotiation coach",
      "I need negotiation coach",
      "help with negotiation",
      "help with salary",
      "help with raise"
    ],
    "context_signals": [
      "user mentions negotiation or salary topics"
    ]
  },
  "deactivation": {
    "explicit_command": "@default",
    "phrases": [
      "done",
      "exit",
      "exit negotiation-coach",
      "stop negotiation coach",
      "back to normal"
    ],
    "auto_deactivate": {
      "after_unrelated_turns": 3,
      "on_session_end": true,
      "after_minutes_idle": 30
    }
  },
  "scope": "session",
  "singleton": true,
  "persona_name": "Anchor"
}