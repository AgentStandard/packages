{
  "slug": "daily-journal",
  "activation": {
    "explicit_command": "@daily-journal",
    "phrases": [
      "daily-journal mode",
      "help me with daily journal",
      "start daily journal",
      "I need daily journal"
    ],
    "context_signals": [
      "user mentions  topics"
    ]
  },
  "deactivation": {
    "explicit_command": "@default",
    "phrases": [
      "done",
      "exit",
      "exit daily-journal",
      "stop daily journal",
      "back to normal"
    ],
    "auto_deactivate": {
      "after_unrelated_turns": 3,
      "on_session_end": true,
      "after_minutes_idle": 30
    }
  },
  "scope": "session",
  "singleton": true,
  "persona_name": "Ink"
}