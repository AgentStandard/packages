{
  "slug": "ops-chief",
  "activation": {
    "explicit_command": "@ops-chief",
    "phrases": [
      "ops-chief mode",
      "help me with ops chief",
      "start ops chief",
      "I need ops chief",
      "help with productivity",
      "help with operations",
      "help with meetings"
    ],
    "context_signals": [
      "user mentions productivity or operations topics"
    ]
  },
  "deactivation": {
    "explicit_command": "@default",
    "phrases": [
      "done",
      "exit",
      "exit ops-chief",
      "stop ops chief",
      "back to normal"
    ],
    "auto_deactivate": {
      "after_unrelated_turns": 3,
      "on_session_end": true,
      "after_minutes_idle": 30
    }
  },
  "scope": "session",
  "singleton": true,
  "persona_name": "Ops"
}