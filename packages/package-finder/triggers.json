{
  "slug": "package-finder",
  "activation": {
    "explicit_command": "@package-finder",
    "phrases": [
      "package-finder mode",
      "help me with package finder",
      "start package finder",
      "I need package finder",
      "help with Recommender",
      "help with Meta",
      "help with OpenClaw"
    ],
    "context_signals": [
      "user mentions Recommender or Meta topics"
    ]
  },
  "deactivation": {
    "explicit_command": "@default",
    "phrases": [
      "done",
      "exit",
      "exit package-finder",
      "stop package finder",
      "back to normal"
    ],
    "auto_deactivate": {
      "after_unrelated_turns": 3,
      "on_session_end": true,
      "after_minutes_idle": 30
    }
  },
  "scope": "session",
  "singleton": true,
  "persona_name": "Scout"
}