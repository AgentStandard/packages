      "version": "1.0.0",
      "description": "Research docs, Stack Overflow, and technical references."
    }
  ],

  "mcps": [],

  "config": {
    "env_vars": [
      {
        "key": "ANTHROPIC_API_KEY",
        "description": "Your Claude API key",
        "required": true,
        "sensitive": true,
        "where_to_get": "https://console.anthropic.com/api-keys"
      },
      {
        "key": "GITHUB_TOKEN",
        "description": "GitHub personal access token for PR and CI access",
        "required": true,
        "sensitive": true,
        "where_to_get": "https://github.com/settings/tokens"
      }
    ]
  },

  "setup_steps": [
    {
      "order": 1,
      "title": "Install OpenClaw",
      "description": "Download and install OpenClaw.",
      "url": "https://openclaw.ai/download",
      "estimated_minutes": 3,
      "type": "install"
    },
    {
      "order": 2,
      "title": "Add your API keys",
      "description": "Add your Claude API key and GitHub token to OpenClaw settings.",
      "estimated_minutes": 3,
      "type": "config"
    },
    {
      "order": 3,
      "title": "Install dev skills",
      "description": "Install the developer productivity skill package.",
      "command": "openclaw skills install github web-search",
      "estimated_minutes": 3,
      "type": "command"
    },
    {
      "order": 4,
      "title": "Connect your repo",
      "description": "Ask: \"Check my open PRs and flag anything that needs review.\" Your agent will pull from GitHub directly.",
      "estimated_minutes": 2,
      "type": "done"
    }
  ],

