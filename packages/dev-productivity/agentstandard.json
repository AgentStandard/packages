  "skills": [
    {
      "name": "github",
      "source": "clawhub",
      "url": "https://clawhub.com/skills/github",
      "version": "1.0.0",
      "description": "GitHub operations — issues, PRs, CI runs, code review via gh CLI."
    },
    {
      "name": "web-search",
      "source": "clawhub",
